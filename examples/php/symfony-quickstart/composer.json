{
    "name": "poly-agntcy/example-symfony-quickstart",
    "type": "project",
    "description": "Symfony quickstart for poly-agntcy/dir-symfony",
    "license": "Apache-2.0",
    "require": {
        "php": "^8.2",
        "symfony/framework-bundle": "^7.0",
        "symfony/console": "^7.0",
        "poly-agntcy/dir-symfony": "*"
    },
    "repositories": [
        { "type": "path", "url": "../../../php/packages/dir" },
        { "type": "path", "url": "../../../php/packages/dir-symfony" }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
